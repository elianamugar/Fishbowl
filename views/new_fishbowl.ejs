<h2>Create a Fishbowl</h2>
<div class="card">
  <% if (messages && messages.length) { %>
    <div class="flash">
      <% messages.forEach(m => { %>
        <div class="flash-<%= m.type %>"><%= m.text %></div>
      <% }) %>
    </div>
  <% } %>
  <form action="/fishbowls" method="POST">
    <label>Name</label>
    <input type="text" name="name" required value="<%= (old && old.name) ? old.name : '' %>" />
    <label>Description</label>
    <textarea name="description"><%= (old && old.description) ? old.description : '' %></textarea>
    <div style="margin-top:12px">
      <button type="submit">Create Fishbowl</button>
    </div>
  </form>
</div>
