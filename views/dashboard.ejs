<div class="card">
  <h2>Members — <%= community.name %></h2>

  <table>
  <thead>
    <tr><th>Name</th><th>Role</th><th>Actions</th></tr>
  </thead>
  <tbody>
    <% members.forEach(m => { %>
      <tr>
        <td><%= m.name %></td>
        <td><%= m.role || (m.is_admin ? 'admin' : 'member') %></td>
        <td>
          <% if (m.role === 'admin' || m.is_admin === 1) { %>
            <form method="POST" action="/fishbowls/<%= community.slug %>/members/<%= m.id %>/role" style="display:inline">
              <input type="hidden" name="role" value="member">
              <button>Demote to member</button>
            </form>
          <% } else { %>
            <form method="POST" action="/fishbowls/<%= community.slug %>/members/<%= m.id %>/role" style="display:inline">
              <input type="hidden" name="role" value="admin">
              <button>Promote to admin</button>
            </form>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
  <p style="margin-top:12px"><a href="/fishbowls/<%= community.slug %>">Back</a></p>
 
<hr>

<section class="danger-zone">
  <h2>Danger Zone</h2>
  <p>Deleting this Fishbowl will permanently remove its monthly updates and memberships.</p>

  <form
    method="POST"
    action="/fishbowls/<%= community.id %>/delete"
    onsubmit="return confirm('Are you sure you want to delete this Fishbowl? This cannot be undone.');"
  >
    <button class="danger-button" type="submit">Delete Fishbowl</button>
  </form>
</section>
</div>
