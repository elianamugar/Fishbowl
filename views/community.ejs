<section class="hero-card">
  <p class="eyebrow">Community</p>
  <h1><%= community.name %></h1>
  <p><%= community.description %></p>

  <div class="actions">
    <a class="button secondary" href="/fishbowls/<%= community.id %>/join">Join community</a>
    <a class="button secondary" href="/fishbowls/<%= community.id %>/members">View members</a>

    <% if (isAdmin) { %>
      <a class="button" href="/fishbowls/<%= community.id %>/new-post">Post monthly update</a>
      <a class="button secondary" href="/fishbowls/<%= community.id %>/dashboard">Manage members</a>
    <% } %>
  </div>
</section>

<section class="updates-feed">
  <div class="section-heading">
    <p class="eyebrow">Monthly Updates</p>
    <h2>Community Feed</h2>
  </div>

  <% if (Object.keys(groups).length === 0) { %>
    <div class="empty-state">
      <h3>No updates yet</h3>
      <p>This community has not posted a monthly update yet.</p>

      <% if (isAdmin) { %>
        <a class="button" href="/fishbowls/<%= community.id %>/new-post">Post the first update</a>
      <% } %>
    </div>
  <% } else { %>
    <% Object.keys(groups).forEach(label => { %>
      <div class="month-section">
        <h3><%= label %></h3>

        <div class="feed-list">
          <% groups[label].forEach(p => { %>
            <article class="update-card">
              <div class="update-meta">
                <span><%= new Date(p.created_at).toLocaleDateString() %></span>
              </div>

              <h4><%= p.title %></h4>
              <p><%= p.content %></p>
            </article>
          <% }) %>
        </div>
      </div>
    <% }) %>
  <% } %>
</section>