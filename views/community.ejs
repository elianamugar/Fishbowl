<section class="community-hero">
  <p class="eyebrow">Community</p>
  <h1><%= community.name %></h1>
  <p class="community-description"><%= community.description %></p>

  <div class="actions">
    <a class="button secondary" href="/fishbowls/<%= community.id %>/join">Join community</a>
    <a class="button secondary" href="/fishbowls/<%= community.id %>/members">View members</a>

    <% if (isAdmin) { %>
      <a class="button" href="/fishbowls/<%= community.id %>/new-post">Post monthly update</a>
      <a class="button secondary" href="/fishbowls/<%= community.id %>/dashboard">Manage members</a>
    <% } %>
  </div>
</section>

<section class="updates-feed">
  <div class="feed-header">
    <p class="eyebrow">Monthly Updates</p>
    <h2>Community Feed</h2>
  </div>

  <% if (Object.keys(groups).length === 0) { %>
    <div class="empty-state">
      <h3>No updates yet</h3>
      <p>This community has not posted a monthly update yet.</p>

      <% if (isAdmin) { %>
        <a class="button" href="/fishbowls/<%= community.id %>/new-post">Post the first update</a>
      <% } %>
    </div>
  <% } else { %>
    <% Object.keys(groups).forEach(label => { %>
      <section class="month-section">
        <h3><%= label %></h3>

        <div class="post-list">
          <% groups[label].forEach(p => { %>
            <article class="post-card">
              <div class="post-meta">
                <span class="post-author"><%= p.author_name || 'Unknown user' %></span>
                <span>•</span>
                <span><%= new Date(p.created_at).toLocaleDateString() %></span>
              </div>

              <h4><%= p.title %></h4>
              <p><%= p.content %></p>
              <div class="comments">
  <h5>Comments</h5>

  <% if (p.comments && p.comments.length > 0) { %>
    <% p.comments.forEach(comment => { %>
      <div class="comment">
        <strong><%= comment.commenter_name %></strong>
        <span>• <%= new Date(comment.created_at).toLocaleDateString() %></span>
        <p><%= comment.content %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p class="muted">No comments yet.</p>
  <% } %>

  <% if (currentUser) { %>
    <form method="POST" action="/posts/<%= p.id %>/comments" class="comment-form">
      <textarea name="content" placeholder="Write a comment..." required></textarea>
      <button type="submit">Comment</button>
    </form>
  <% } else { %>
    <p><a href="/login">Log in</a> to comment.</p>
  <% } %>
</div>
            </article>
          <% }) %>
        </div>
      </section>
    <% }) %>
  <% } %>
</section>